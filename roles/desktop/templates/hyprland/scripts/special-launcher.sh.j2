#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'
PATH=$PATH:/usr/local/bin

{{ ansible_managed | comment }}

if hyprctl clients -j | grep -q "\"name\": \"special:$1\""; then
  # App is running, just toggle visibility
  hyprctl dispatch togglespecialworkspace "$1"
else
  # App not running, launch it — windowrule will place it on the right workspace
  if [ "$1" == "terminal" ]; then
    kitty --class "$1" &
  elif [ "$2" == "terminal" ]; then
    kitty --class "$1" "$1" &
  else
    ${@:2} &
  fi
fi
