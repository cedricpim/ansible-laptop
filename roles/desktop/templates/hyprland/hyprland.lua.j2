local hyprlandDirectory = [==[{{ hyprland_directory }}]==]
local menu = hyprlandDirectory .. "/scripts/rofi.sh -show drun -modi drun,filebrowser,run,window"
local mainMod = "SUPER"

local home = os.getenv("HOME")
local walColors = dofile(home .. "/.cache/wal/colors-hyprland.lua")

local layoutLocked = false
local function setInternalMonitor(enabled)
    hl.monitor({
        output = "eDP-1",
        disabled = not enabled,
        mode = "preferred",
        position = "auto",
        scale = 1.5,
    })
end
local function setExternalMonitor(enabled)
    hl.monitor({
        output = "DP-2",
        disabled = not enabled,
        mode = "preferred",
        position = "auto",
        scale = 1,
    })
end
local function externalMonitorCount()
	local count = 0

	for _, monitor in ipairs(hl.get_monitors()) do
		if not monitor.name:match("^eDP%-") then
			count = count + 1
		end
	end

	return count
end
local function unlockLayoutSoon()
	hl.timer(function()
		layoutLocked = false
	end, {
		timeout = 500,
		type = "oneshot",
	})
end
local function setMonitorLayout(layout)
	layoutLocked = true

	if layout == "internal" then
		setInternalMonitor(true)
		setExternalMonitor(false)
	elseif layout == "external" then
		setExternalMonitor(true)
		setInternalMonitor(false)
	elseif layout == "multiple" then
		setExternalMonitor(true)
		setInternalMonitor(true)
	end

	unlockLayoutSoon()
end

hl.on("monitor.added", function()
	if not layoutLocked and externalMonitorCount() > 0 then
		setInternalMonitor(false)
	end
end)

hl.on("monitor.removed", function()
	if externalMonitorCount() == 0 then
		setInternalMonitor(true)
	end
end)

hl.monitor({
	output = "",
	mode = "preferred",
	position = "auto",
	scale = "auto",
})

hl.on("hyprland.start", function()
    hl.exec_cmd("dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP")
    hl.exec_cmd("systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP")
    hl.exec_cmd("systemctl --user start hyprland-session.target")

    hl.exec_cmd("hyprpaper")
    hl.exec_cmd("hypridle")
    hl.exec_cmd("hyprsunset")
    hl.exec_cmd("hyprpm reload -n")

    hl.exec_cmd("slack")
    hl.exec_cmd("swaync")
    hl.exec_cmd("udiskie -ans")
    hl.exec_cmd("blueman-applet")
    hl.exec_cmd("solaar -w hide")
    hl.exec_cmd("nm-applet --indicator")
    hl.exec_cmd("sudo rm /tmp/osui.sock >/dev/null 2>&1 || true && opensnitch-ui --background")
    hl.exec_cmd("signal-desktop --start-in-tray")
    hl.exec_cmd("wl-paste --type text --watch cliphist store")
    hl.exec_cmd("wl-paste --type image --watch cliphist store")

    hl.exec_cmd([==[{{ default_browser }}]==])

    hl.exec_cmd("sleep 1 && keepassxc")
    hl.exec_cmd("sleep 1 && mullvad-vpn")
end)

