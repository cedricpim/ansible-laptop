{{ ansible_managed | comment(decoration='-- ', prefix='--[[', postfix='--]]') }}

return function(context)
    local hyprlandDirectory = context.hyprlandDirectory
    local mainMod = context.mainMod
    local menu = context.menu

    hl.bind(mainMod .. " + RETURN", hl.dsp.exec_cmd("kitty"))
    hl.bind(mainMod .. " + Q", hl.dsp.window.close())
    hl.bind(mainMod .. " + F", hl.dsp.window.fullscreen({}))
    hl.bind(mainMod .. " + SHIFT + O", hl.dsp.window.float({ action = "toggle" }))
    hl.bind(mainMod .. " + D", hl.dsp.exec_cmd("pkill rofi || " .. menu), { release = true })
    hl.bind(mainMod .. " + SHIFT + J", hl.dsp.layout("togglesplit"))
    hl.bind(mainMod .. " + GRAVE", hl.dsp.exec_cmd("swaync-client --toggle-dnd"))
    hl.bind(mainMod .. " + SHIFT + GRAVE", hl.dsp.exec_cmd("swaync-client -t -sw"))
    hl.bind(mainMod .. " + Tab", hl.dsp.window.cycle_next({ next = false }))
    hl.bind(mainMod .. " + SHIFT + R", hl.dsp.exec_cmd("hyprctl reload"))
    hl.bind("Print", hl.dsp.exec_cmd("hyprshot -m region --clipboard-only"))
    hl.bind(mainMod .. " + Print", hl.dsp.exec_cmd("hyprshot -m region"))
    hl.bind(mainMod .. " + SHIFT + P", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/wlogout.sh"))
    hl.bind(mainMod .. " + C", hl.dsp.exec_cmd("pkill rofi || " .. hyprlandDirectory .. "/scripts/clip-manager.sh"), { release = true })

    hl.bind(mainMod .. " + LEFT", hl.dsp.focus({ direction = "l" }))
    hl.bind(mainMod .. " + RIGHT", hl.dsp.focus({ direction = "r" }))
    hl.bind(mainMod .. " + UP", hl.dsp.focus({ direction = "u" }))
    hl.bind(mainMod .. " + DOWN", hl.dsp.focus({ direction = "d" }))
    hl.bind(mainMod .. " + H", hl.dsp.focus({ direction = "l" }))
    hl.bind(mainMod .. " + L", hl.dsp.focus({ direction = "r" }))
    hl.bind(mainMod .. " + K", hl.dsp.focus({ direction = "u" }))
    hl.bind(mainMod .. " + J", hl.dsp.focus({ direction = "d" }))

    hl.bind(mainMod .. " + SHIFT + H", hl.dsp.window.move({ direction = "l" }))
    hl.bind(mainMod .. " + SHIFT + L", hl.dsp.window.move({ direction = "r" }))

{% for workspace in workspaces %}
    hl.bind(mainMod .. " + " .. [==[{{ workspace.keybinding }}]==], hl.dsp.focus({ workspace = [==[{{ workspace.key }}]==] }))
    hl.bind(mainMod .. " + SHIFT + " .. [==[{{ workspace.keybinding }}]==], hl.dsp.window.move({ workspace = [==[{{ workspace.key }}]==] }))
{% if workspace.assigned is defined %}
    hl.window_rule({
        match = { class = [==[^({{ workspace.assigned }})$]==] },
        workspace = [==[{{ workspace.key }} silent]==],
    })
{% endif %}

{% endfor %}
    hl.bind(mainMod .. " + EQUAL", hl.dsp.workspace.toggle_special("magic"))
    hl.bind(mainMod .. " + MINUS", hl.dsp.window.move({ workspace = "special:magic" }))

    hl.bind(mainMod .. " + mouse_down", hl.dsp.focus({ workspace = "e+1" }))
    hl.bind(mainMod .. " + mouse_up", hl.dsp.focus({ workspace = "e-1" }))

    hl.bind(mainMod .. " + SHIFT + mouse:272", hl.dsp.window.drag(), { mouse = true })
    hl.bind(mainMod .. " + SHIFT + mouse:273", hl.dsp.window.resize(), { mouse = true })

    hl.bind("XF86AudioRaiseVolume", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/volume-control.sh --inc"), { locked = true, repeating = true })
    hl.bind("XF86AudioLowerVolume", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/volume-control.sh --dec"), { locked = true, repeating = true })
    hl.bind("XF86AudioMute", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/volume-control.sh --toggle"), { locked = true })
    hl.bind("XF86MonBrightnessUp", hl.dsp.exec_cmd("xbacklight -inc 10"))
    hl.bind("XF86MonBrightnessDown", hl.dsp.exec_cmd("xbacklight -dec 10"))
    hl.bind("XF86AudioPlay", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/media-control.sh --pause"))
    hl.bind("XF86AudioNext", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/media-control.sh --nxt"))
    hl.bind("XF86AudioPrev", hl.dsp.exec_cmd(hyprlandDirectory .. "/scripts/media-control.sh --prv"))

    hl.bind(mainMod .. " + SHIFT + S", hl.dsp.submap("resize"))
    hl.bind(mainMod .. " + SHIFT + M", hl.dsp.submap("displays"))
    hl.bind("ALT + L", hl.dsp.submap("passthrough"))
end
