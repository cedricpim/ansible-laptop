{{ ansible_managed | comment(decoration='// ') }}

{
  // HYPRLAND WORKSPACES. CHOOSE as desired and place on waybar configs
  // CIRCLES Style
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
    },
    "format-icons": {
      "active": "´åÆ",
      "default": "´äî",
    },
  },

  //  NUMBERS and ICONS style
  "hyprland/workspaces#2": {
    "format": "{icon}",
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "sort-by-number": true,
    "format-icons": {
      {% for workspace in workspaces %}
"{{ workspace.key }}": "{{ workspace.symbol | default(workspace.key) }}",
      {% endfor %}
"focused": "´åÆ",
      "default": "´äî",
    },
  },

  // GROUP

  "group/motherboard": {
    "orientation": "horizontal",
    "modules": [ "cpu", "memory", "temperature" ]
  },

  "cpu": {
    "format": "{usage}% ¾░ıø",
    "interval": 1,
    "format-alt-click": "click",
    "format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% ¾░ıø",
    "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"],
    "on-click": "gnome-system-monitor",
  },

  "memory": {
    "interval": 10,
    "format": "{used:0.1f}G ¾░¥å",
    "format-alt": "{percentage}% ¾░¥å",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click": "kitty --title btop -e btop"
  },

  "temperature": {
    "interval": 10,
    "tooltip": true,
    "hwmon-path": ["/sys/class/hwmon/hwmon1/temp1_input", "/sys/class/thermal/thermal_zone0/temp"],
    //"thermal-zone": 0,
    "critical-threshold": 82,
    "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["¾░ê©"],
    "on-click": "kitty --title nvtop -e nvtop"
  },

  "disk": {
    "interval": 30,
    //"format": "¾░ïè",
    "path": "/",
    //"format-alt-click": "click",
    "format": "{percentage_used}% ¾░ïè",
    //"tooltip": true,
    "tooltip-format": "{used} used out of {total} on {path} ({percentage_used}%)",
  },

  "group/laptop": {
    "orientation": "horizontal",
    "modules": [ "backlight", "battery" ]
  },

  "backlight": {
    "interval": 2,
    "align": 0,
    "rotate": 0,
    //"format": "{icon} {percent}%",
    "format-icons": ["¯Åò ", "¯Åù ", "¯ÅÜ ", "¾░âØ ", "¾░âŞ ", "¾░âş ", "¾░âá "],
    "format": "{icon}",
    //"format-icons": ["¯Åò","¯Åû","¯Åù","¯Åİ","¯ÅÖ","¯ÅÜ","¯Åø","¯Å£","¯ÅØ","¯ÅŞ","¯Åş","¯Åá","¯Åí","¯Åó","¯Åú"],
    "tooltip-format": "backlight {percent}%",
    "icon-size": 10,
    "on-click": "",
    "on-click-middle": "",
    "on-click-right": "",
    "on-update": "",
    "on-scroll-up": "{{ waybar_directory }}/scripts/brightness.sh --inc",
    "on-scroll-down": "{{ waybar_directory }}/scripts/brightness.sh --dec",
    "smooth-scrolling-threshold": 1,
  },

  "battery": {
    //"interval": 5,
    "align": 0,
    "rotate": 0,
    //"bat": "BAT1",
    //"adapter": "ACAD",
    "full-at": 100,
    "design-capacity": false,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´âğ{capacity}%",
    "format-plugged": "¾▒İû {capacity}%",
    "format-alt-click": "click",
    "format-full": "{icon} Full",
    "format-alt": "{icon} {time}",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
    "format-time": "{H}h {M}min",
    "tooltip": true,
    "tooltip-format": "{timeTo} {power}w",
    "on-click": "gnome-power-statistics",
    "on-click-right": "{{ hyprland_directory }}/scripts/wlogout.sh",
  },

  "group/audio": {
    "orientation": "horizontal",
    "modules": [ "pulseaudio", "pulseaudio#microphone" ]
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} ¾░é░ {volume}%",
    "format-muted": "¾░ûü",
    "format-bluetooth": "¾░é░",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ÇÑ",
      "headset": "´ÇÑ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´ÇĞ", "´Çğ", "¾░ò¥", "´Ç¿"], 
      "ignored-sinks": ["Easy Effects Sink"],
    },
    "scroll-step": 5.0,
    "on-click-right": "{{ hyprland_directory }}/scripts/volume-control.sh --toggle",
    "on-click": "pavucontrol -t 3",
    "on-scroll-up": "{{ hyprland_directory }}/scripts/volume-control.sh --inc",
    "on-scroll-down": "{{ hyprland_directory }}/scripts/volume-control.sh --dec",
    "tooltip-format": "{icon} {desc} | {volume}%",
    "smooth-scrolling-threshold": 1,
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "´ä░  {volume}%",
    "format-source-muted": "´ä▒",
    "on-click-right": "{{ hyprland_directory }}/scripts/volume-control.sh --toggle-mic",
    "on-click": "pavucontrol -t 4",
    "on-scroll-up": "{{ hyprland_directory }}/scripts/volume-control.sh --mic-inc",
    "on-scroll-down": "{{ hyprland_directory }}/scripts/volume-control.sh --mic-dec",
    "tooltip-format": "{source_desc} | {source_volume}%",
    "scroll-step": 5,
  },

  "bluetooth": {
    "format": "´èô",
    "format-disabled": "¾░é│",
    "format-connected": "¾░é▒ {num_connections}",
    "tooltip-format": "´èô {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "´èô {device_alias} ¾░éä{device_battery_percentage}%",
    "tooltip": true,
    "on-click": "blueman-manager",
  },

  "clock": {
    "interval": 1,
    //"format": "´Çù {:%I:%M %p}", // AM PM format
    "format": "´Çù  {:%H:%M - %d/%b}", // 24H
    "format-alt": "´Çù  {:%H:%M  ´ü│ %Y, %d %B, %A}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },

  "hyprland/submap": {
    "format": "<span style=\"italic\">´îŞ  {}</span>", // Icon: expand-arrows-alt
    "tooltip": false,
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "separate-outputs": true,
    "offscreen-css" : true,
    "offscreen-css-text": "(inactive)",
     "rewrite": {
       "(.*) ÔÇö Mozilla Firefox": "´ë®  $1",
       "(.*) - zsh": "> [$1]",
       "(.*) - kitty": "> [$1]",
       "(.*) - NVIM": "´äí  $1",
    },
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´êà ",
      "deactivated": "´êä ",
    }
  },

  "mpris": {
    "interval": 10,
    "format": "{dynamic} {player_icon}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "on-scroll-up": "{{ hyprland_directory }}/scripts/volume-control.sh --inc",
    "on-scroll-down": "{{ hyprland_directory }}/scripts/volume-control.sh --dec",
    "smooth-scrolling-threshold": 1,
    "player-icons": {
      "chromium": "´ë¿",
      "default": "´ÇØ",
      "firefox": "´ë®",
      "kdeconnect": "´İş",
      "mopidy": "´Çü",
      "mpv": "¾░É╣",
      "spotify": "´å╝",
      "vlc": "¾░ò╝",
    },
    "status-icons": {
      "paused": "¾░ÉÄ",
      "playing": "´üï",
      "stopped": "´üı",
    },
    "dynamic-order": [ "title", "artist", "album" ],
    "dynamic-len": 30,
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "¾░îİ",
    "format-disconnected": "¾░îÖ",
    "tooltip-format": "{ipaddr} ´ä╣ {bandwidthUpBytes} ´ä║ {bandwidthDownBytes}",
    "format-linked": "¾░êü {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ¾░îİ",
    "tooltip-format-disconnected": "¾░îÖ Disconnected",
    "max-length": 50,
    "format-icons": ["¾░ñ»","¾░ñş","¾░ñó","¾░ñÑ","¾░ñ¿"]
  },

  "network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "{signalStrength}% {icon}",
    "format-ethernet": "¾░îİ",
    "format-disconnected": "¾░îÖ",
    "tooltip-format": "{ipaddr}",
    "format-linked": "¾░êü {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} | ´ä╣  {bandwidthUpBytes} ´ä║  {bandwidthDownBytes}",
    "tooltip-format-ethernet": "{ifname} | ´ä╣  {bandwidthUpBytes} ´ä║  {bandwidthDownBytes}",
    "tooltip-format-disconnected": "¾░îÖ  Disconnected",
    "max-length": 50,
    "format-icons": ["¾░ñ»","¾░ñş","¾░ñó","¾░ñÑ","¾░ñ¿"]
  },

  "tray": {
    "icon-size": 15,
    "spacing": 8,
  },

  "custom/power": {
    "format": "ÔÅ╗ ",
    "exec": "echo ; echo ¾░şí power // blur",
    "on-click": "{{ hyprland_directory }}/scripts/wlogout.sh",
    "interval" : 86400, // once every day
    "tooltip": true,
  },

  "custom/swaync": {
    "tooltip":true,
    "format": "{icon} {0}",
    "format-icons": {
      "notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "none": "´éó",
      "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-none": "´çÀ",
      "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-inhibited-none": "´çÀ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },

  "custom/weather": {
    "format": "{}",
    "format-alt": "{alt}: {0}",
    "format-alt-click": "click",
    "interval": 3600,
    "return-type": "json",
    "exec": "{{ waybar_directory }}/scripts/weather.sh",
    "exec": "{{ waybar_directory }}/scripts/weather.py",
    "exec-if": "ping wttr.in -c1",
    "tooltip" : true,
  },

  // Separators

  "custom/separator#dot": {
    "format": "´æä",
    "interval": "once",
    "tooltip": false
  },

  "custom/separator#dot-line": {
    "format": "¯İí",
    "interval": "once",
    "tooltip": false
  },

  "custom/separator#line": {
    "format": "|",
    "interval": "once",
    "tooltip": false
  },

  "custom/separator#blank": {
    "format": "",
    "interval": "once",
    "tooltip": false
  },

  "custom/separator#blank_2": {
    "format": "  ",
    "interval": "once",
    "tooltip": false
  },

  "custom/separator#blank_3": {
    "format": "   ",
    "interval": "once",
    "tooltip": false
  },
}
